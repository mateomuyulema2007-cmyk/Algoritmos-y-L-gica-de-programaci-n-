
         #include <iostream>
         using namespace std;

         int main() {
             string dni;
             float saldos[3] = {0.0, 0.0, 0.0};
             int opcion, cta1, cta2;
             float monto;

         cout << "Sistema Bancario"<<endl;
         cout << "Ingrese DNI: ";
         cin >> dni;

        do {
            cout << "1. Ver cuentas " << endl;
            cout << "2. Depositar " << endl,
            cout << "3. Transferir"<< endl;
            cout << "4. Salir"<< endl;
            cout << "Opcion: "<< endl;
            cin >> opcion;

        switch(opcion) {
            case 1:
                for(int i=0; i<3; i++) cout << "Cuenta " << i+1 << ": $" << saldos[i] << endl;
                break;
            case 2:
                cout << "Num cuenta (1-3) y monto a depositar: ";
                cin >> cta1 >> monto;
                saldos[cta1-1] += monto;
                cout << "Deposito exitoso.\n";
                break;
            case 3:
                cout << "Cuenta origen (1-3), Cuenta destino (1-3) y monto: ";
                cin >> cta1 >> cta2 >> monto;
                if(saldos[cta1-1] >= monto) {
                    saldos[cta1-1] -= monto;
                    saldos[cta2-1] += monto;
                    cout << "Transferencia exitosa.\n";
                } else cout << "Fondos insuficientes.\n";
                break;
           }
         } while(opcion != 4);{
                cout << "Fin del sistema ";
        }

          return 0;
      }

